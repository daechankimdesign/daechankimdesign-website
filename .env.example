# ─────────────────────────────────────────────────────────────────────────────
# Environment variables template. Copy to `.env.local` and fill in real values.
# `.env.local` is gitignored and must NEVER be committed.
#
# In production (Firebase App Hosting), these are set in `apphosting.yaml`
# (public NEXT_PUBLIC_* values) and Cloud Secret Manager (server secrets).
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase client config (public; inlined into the browser bundle) ─────────
# From Firebase console → Project settings → Your apps → Web app → SDK config.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase App Check (public reCAPTCHA v3 site key) ────────────────────────
# Used to block off-app abuse of the translation Server Action (Phase 6).
NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=
# Local-only App Check debug token (dev). Never set in production.
# NEXT_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN=

# ── Server-only secrets (NEVER expose to the client) ─────────────────────────
# Google Cloud / Gemini API key for the translation pipeline (Phases 6–7).
GEMINI_API_KEY=

# ── Firebase Admin SDK (server) ──────────────────────────────────────────────
# On App Hosting / Cloud Run, Application Default Credentials are used
# automatically — no key file needed. For LOCAL dev only, point to a
# downloaded service-account JSON (kept out of git):
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
