rules_version = '2';

// Phase 5 collections — both written/read ONLY by the server via the Firebase
// Admin SDK, which bypasses these rules:
//   translations/{slug}_{locale}  — cached translated MDX (status, mdx, frontmatter, sourceHash, lockId)
//   rateLimits/{uid}_{slug}_{locale} — windowed per-user trigger guard; `expiresAt`
//     has a Firestore TTL policy (see firestore.indexes.json) so it self-cleans
// Deny-all keeps the client SDK from ever writing translated content directly.
// Loosen specific paths only if the client ever needs to read directly.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
