rules_version = '2';

// Translation cache (`translations/{slug}_{locale}`) and rate-limit records are
// accessed only by the server via the Firebase Admin SDK, which bypasses these
// rules. Client SDK access is denied by default. Loosen specific paths in
// Phase 6 only if the client ever needs to read directly.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
