# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (real secrets stay local; the documented template is committed)
.env*
!.env.example

# secrets / service-account keys (NEVER commit)
*service-account*.json
serviceAccount*.json
*.serviceaccount.json

# firebase
.firebase/
firebase-debug.log*
firestore-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local-only design reference (not deployed)
/src/app/\[locale\]/design-rules/
Legacy Portfolio/Translate furniture as a service to tackle social phenomenon..md
Portfolio Ideation/Case Study Format.md
Portfolio Ideation/Oria Portfolio.md
Portfolio Ideation/Design Ethos.md
